# ─────────────────────────────────────────────────────────────
# StoryMax environment variables
# Copy this file to `.env` (loaded by backend via dotenv in server.js).
# In production (Railway / Sevalla) set these in the platform's env settings.
# ─────────────────────────────────────────────────────────────

# Server port (backend). Defaults to 5022 if unset.
PORT=5022

# ── Security ──
# REQUIRED in production: secret used to sign & verify JWT auth tokens.
# If unset in production the server refuses to boot (see config/secrets.js).
# Generate a strong value, e.g.:  openssl rand -hex 32
JWT_SECRET=

# ── AI endpoint (OpenAI-compatible) ──
# Used for prompt splitting, auto prompt writing, and video-prompt generation.
# AI_API_TOKEN must be provided via env (never hardcoded in source).
AI_API_HOST=http://localhost:8045/v1
AI_API_TOKEN=
AI_MODEL=gemini-3-flash

# ── Default admin seed (first boot only) ──
# Set SEED_DEFAULT_ADMIN=false to skip auto-seeding an admin user.
# Always change the password after first login.
SEED_DEFAULT_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_now

# ── Optional ──
# Override the uploads directory (defaults to backend/public/uploads).
# UPLOADS_DIR=

# ── Frontend (Vite) ──
# API base URL for the frontend. Leave empty to use same-origin '/api'.
# VITE_API_URL=
